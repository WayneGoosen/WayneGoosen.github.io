---
// Contact section with form that posts to Azure Function API
const contactApiUrl = import.meta.env.PUBLIC_CONTACT_API_URL || ''
---

<section id='contact' class='py-24 bg-obsidian scroll-mt-24'>
	<div class='container mx-auto px-6'>
		<div
			class='max-w-5xl mx-auto rounded-[2.5rem] bg-slate-900 border border-slate-800 overflow-hidden flex flex-col md:flex-row shadow-2xl'
		>
			<div class='md:w-1/2 p-8 md:p-16 bg-slate-950'>
				<h2 class='text-4xl font-bold mb-6 text-white tracking-tighter'>
					Let's build something scalable.
				</h2>
				<p class='text-slate-400 mb-8 leading-relaxed font-light'>
					Whether you need a full platform overhaul, a customized training session for your team, or
					a technical advisor for your startup, I'm here to help.
				</p>

				<div class='space-y-6'>
					<div class='flex items-center gap-4 group'>
						<div
							class='w-12 h-12 rounded-xl bg-slate-900 flex items-center justify-center text-orange-500 border border-slate-800 group-hover:bg-orange-600 group-hover:text-white transition-all shadow-[0_0_15px_rgba(249,115,22,0.1)]'
						>
							<svg
								xmlns='http://www.w3.org/2000/svg'
								class='h-6 w-6'
								fill='none'
								viewBox='0 0 24 24'
								stroke='currentColor'
							>
								<path
									stroke-linecap='round'
									stroke-linejoin='round'
									stroke-width='2'
									d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
								></path>
							</svg>
						</div>
						<div>
							<p class='text-xs text-slate-500 font-bold uppercase tracking-wider'>Email me at</p>
							<a
								href='mailto:wayne@waynegoosen.com'
								class='text-lg font-medium text-white hover:text-orange-400 transition-colors'
								>wayne@waynegoosen.com</a
							>
						</div>
					</div>

					<div class='flex items-center gap-4 group'>
						<div
							class='w-12 h-12 rounded-xl bg-slate-900 flex items-center justify-center text-orange-500 border border-slate-800 group-hover:bg-orange-600 group-hover:text-white transition-all shadow-[0_0_15px_rgba(249,115,22,0.1)]'
						>
							<svg
								xmlns='http://www.w3.org/2000/svg'
								class='h-6 w-6'
								fill='none'
								viewBox='0 0 24 24'
								stroke='currentColor'
							>
								<path
									stroke-linecap='round'
									stroke-linejoin='round'
									stroke-width='2'
									d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
							</svg>
						</div>
						<div>
							<p class='text-xs text-slate-500 font-bold uppercase tracking-wider'>Based in</p>
							<p class='text-lg font-medium text-white'>GMT+2 Timezone (Remote Worldwide)</p>
						</div>
					</div>
				</div>
			</div>

			<div
				class='md:w-1/2 p-8 md:p-16 border-t md:border-t-0 md:border-l border-slate-800 bg-slate-900/50'
			>
				<form id='contact-form' class='space-y-4'>
					<div class='grid grid-cols-2 gap-4'>
						<div class='space-y-2'>
							<label for='contact-name' class='text-sm font-medium text-slate-400'>Name</label>
							<input
								type='text'
								id='contact-name'
								name='name'
								required
								class='w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:outline-none focus:ring-1 focus:ring-orange-600/50 text-white placeholder:text-slate-700'
								placeholder='John Doe'
							/>
						</div>
						<div class='space-y-2'>
							<label for='contact-email' class='text-sm font-medium text-slate-400'>Email</label>
							<input
								type='email'
								id='contact-email'
								name='email'
								required
								class='w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:outline-none focus:ring-1 focus:ring-orange-600/50 text-white placeholder:text-slate-700'
								placeholder='john@example.com'
							/>
						</div>
					</div>
					<div class='space-y-2'>
						<label for='contact-business' class='text-sm font-medium text-slate-400'
							>Inquiry Type</label
						>
						<div class='relative'>
							<select
								id='contact-business'
								name='business'
								required
								class='w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:outline-none focus:ring-1 focus:ring-orange-600/50 text-white appearance-none cursor-pointer'
							>
								<option value='' disabled selected class='bg-slate-900'
									>Select an inquiry type</option
								>
								<option value='General Inquiry' class='bg-slate-900'>General Inquiry</option>
								<option value='Platform Reality Check (Audit)' class='bg-slate-900'
									>The Platform Reality Check (Audit)</option
								>
								<option value='Golden Path Architecture' class='bg-slate-900'
									>The "Golden Path" Architecture (Done-for-You)</option
								>
								<option value='Platform Orchestration & IDP' class='bg-slate-900'
									>Platform Orchestration & IDP Engineering</option
								>
								<option value='Fractional Platform Lead' class='bg-slate-900'
									>Fractional Platform Lead</option
								>
								<option value='On-Demand DevOps' class='bg-slate-900'
									>On-Demand DevOps & Pipeline Ops</option
								>
								<option value='Team Training / Mentoring' class='bg-slate-900'
									>Custom Team Training / Mentoring</option
								>
								<option value='Other' class='bg-slate-900'>Other</option>
							</select>
							<div
								class='absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-500'
							>
								<svg
									xmlns='http://www.w3.org/2000/svg'
									class='h-4 w-4'
									fill='none'
									viewBox='0 0 24 24'
									stroke='currentColor'
								>
									<path
										stroke-linecap='round'
										stroke-linejoin='round'
										stroke-width='2'
										d='M19 9l-7 7-7-7'></path>
								</svg>
							</div>
						</div>
					</div>
					<div class='space-y-2'>
						<label for='contact-message' class='text-sm font-medium text-slate-400'>Message</label>
						<textarea
							rows='4'
							id='contact-message'
							name='message'
							required
							class='w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:outline-none focus:ring-1 focus:ring-orange-600/50 text-white placeholder:text-slate-700'
							placeholder='Tell me about your project...'></textarea>
					</div>

					<!-- Submit Button -->
					<button
						type='submit'
						id='submit-btn'
						class='w-full py-4 bg-orange-600 hover:bg-orange-500 text-white rounded-xl font-bold transition-all shadow-lg shadow-orange-600/20 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed'
					>
						<span id='btn-text'>Send Message</span>
						<span id='btn-loading' class='hidden'>
							<svg
								class='animate-spin h-5 w-5 mx-auto'
								xmlns='http://www.w3.org/2000/svg'
								fill='none'
								viewBox='0 0 24 24'
							>
								<circle
									class='opacity-25'
									cx='12'
									cy='12'
									r='10'
									stroke='currentColor'
									stroke-width='4'></circle>
								<path
									class='opacity-75'
									fill='currentColor'
									d='M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z'
								></path>
							</svg>
						</span>
					</button>

					<!-- Success Message -->
					<div
						id='success-message'
						class='hidden p-4 rounded-xl bg-emerald-600/10 border border-emerald-600/20 text-emerald-400 text-center'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='h-6 w-6 mx-auto mb-2'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								stroke-width='2'
								d='M5 13l4 4L19 7'></path>
						</svg>
						<p class='font-medium'>Message sent successfully!</p>
						<p class='text-sm text-emerald-400/70 mt-1'>I'll get back to you soon.</p>
					</div>

					<!-- Error Message -->
					<div
						id='error-message'
						class='hidden p-4 rounded-xl bg-red-600/10 border border-red-600/20 text-red-400 text-center'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='h-6 w-6 mx-auto mb-2'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								stroke-width='2'
								d='M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'></path>
						</svg>
						<p class='font-medium'>Something went wrong.</p>
						<p class='text-sm text-red-400/70 mt-1'>Please try again or email me directly.</p>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>

<script define:vars={{ contactApiUrl }}>
	const form = document.getElementById('contact-form')
	const submitBtn = document.getElementById('submit-btn')
	const btnText = document.getElementById('btn-text')
	const btnLoading = document.getElementById('btn-loading')
	const successMessage = document.getElementById('success-message')
	const errorMessage = document.getElementById('error-message')

	const API_URL = contactApiUrl

	form?.addEventListener('submit', async (e) => {
		e.preventDefault()

		// Hide any previous messages
		successMessage?.classList.add('hidden')
		errorMessage?.classList.add('hidden')

		// Validate API URL is configured
		if (!API_URL) {
			console.error('Contact API URL is not configured')
			errorMessage?.classList.remove('hidden')
			return
		}

		// Show loading state
		submitBtn.disabled = true
		btnText?.classList.add('hidden')
		btnLoading?.classList.remove('hidden')

		const formData = new FormData(form)
		const data = {
			name: formData.get('name') as string,
			email: formData.get('email') as string,
			business: formData.get('business') as string,
			message: formData.get('message') as string
		}

		try {
			const response = await fetch(API_URL, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json'
				},
				body: JSON.stringify(data)
			})

			if (!response.ok) {
				throw new Error(`HTTP error! status: ${response.status}`)
			}

			// Show success message
			successMessage?.classList.remove('hidden')
			form.reset()
		} catch (error) {
			console.error('Form submission error:', error)
			errorMessage?.classList.remove('hidden')
		} finally {
			// Reset button state
			submitBtn.disabled = false
			btnText?.classList.remove('hidden')
			btnLoading?.classList.add('hidden')
		}
	})
</script>
