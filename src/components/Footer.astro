---
const currentYear = new Date().getFullYear()

const socialLinks = [
	{ name: 'LinkedIn', url: 'https://linkedin.com/in/waynegoosen' },
	{ name: 'GitHub', url: 'https://github.com/WayneGoosen' },
	{ name: 'Twitter', url: 'https://twitter.com/GoosenWayne' },
	{ name: 'Blog', url: '/blog' },
	{ name: 'For LLMs', url: '/for-llms' }
]
---

<footer class='py-12 border-t border-slate-900 bg-slate-950'>
	<div class='container mx-auto px-6'>
		<div class='flex flex-col md:flex-row justify-between items-center gap-8'>
			<div>
				<div class='text-2xl font-bold tracking-tighter text-white'>Wayne Goosen</div>
			</div>

			<div class='flex gap-8 text-slate-400 font-medium text-sm'>
				{
					socialLinks.map((link) => (
						<a
							href={link.url}
							class='hover:text-orange-400 transition-colors'
							target={link.url.startsWith('http') ? '_blank' : undefined}
							rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
						>
							{link.name}
						</a>
					))
				}
			</div>

			<div class='text-slate-500 text-sm'>
				&copy; {currentYear} Wayne Goosen. All rights reserved.
			</div>
		</div>
	</div>
</footer>
