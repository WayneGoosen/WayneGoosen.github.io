---
import { Image } from 'astro:assets'
import FormattedDate from '@/components/FormattedDate'
import ArrowUp from '@/components/icons/ArrowUp'

const {
	id,
	data: { title, description, pubDate, heroImage, category },
	readTime,
	slug
} = Astro.props
---

<article class='flex flex-col md:flex-row gap-6 group'>
	<a class='relative overflow-hidden md:w-80 flex-shrink-0 rounded-xl' href={`/post/${slug}/`}>
		<Image
			src={heroImage}
			width={320}
			height={200}
			format='webp'
			class='h-48 md:h-full w-full object-cover hover:scale-[102%] transition-all duration-200'
			alt={`img of ${title}`}
		/>
	</a>

	<div class='flex flex-col justify-between flex-1 py-2'>
		<div class='flex flex-col gap-3'>
			<div class='flex items-center gap-4 text-sm text-slate-400'>
				<FormattedDate date={pubDate} />
				<span>·</span>
				<span>{readTime}</span>
				<span>·</span>
				<span class='text-orange-500'>{category}</span>
			</div>

			<a
				class='text-2xl font-semibold -tracking-wider text-white hover:text-orange-400 transition-colors'
				href={`/post/${slug}/`}
			>
				{title}
			</a>

			<p class='overflow-hidden line-clamp-2 text-slate-400 font-light'>
				{description}
			</p>
		</div>

		<footer class='mt-4'>
			<a
				href={`/post/${slug}/`}
				class='inline-flex items-center text-white hover:text-orange-400 transition-colors font-semibold gap-1 group/link'
				aria-label={`go to ${title}`}
			>
				Read Post <span
					class='mt-[1px] group-hover/link:rotate-45 transition-transform duration-250 ease-in-out'
					><ArrowUp width='18' height='18' /></span
				>
			</a>
		</footer>
	</div>
</article>

<script>
	import { animate } from 'motion'

	const images = document.querySelectorAll('img')

	document.addEventListener('DOMContentLoaded', function () {
		const showAnimations = localStorage.getItem('animations') === 'true'

		if (showAnimations) {
			animate(
				'.effect',
				{
					opacity: [0, 1],
					clipPath: ['circle(0% at 0% 0%)', 'circle(100% at 50% 50%)']
				},
				{ duration: 2, easing: 'ease' }
			)
		} else {
			images.forEach((img) => {
				img.classList.remove('opacity-0')
			})
		}
	})
</script>
