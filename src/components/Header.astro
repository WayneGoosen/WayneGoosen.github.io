---
const navLinks = [
	{ label: 'About', href: '/about' },
	{ label: 'Services', href: '/#services' },
	{ label: 'Blog', href: '/blog' },
	{ label: 'Contact', href: '/#contact' }
]

const socialLinks = [
	{ name: 'GitHub', url: 'https://github.com/WayneGoosen' },
	{ name: 'LinkedIn', url: 'https://www.linkedin.com/in/waynegoosen/' },
	{ name: 'Twitter', url: 'https://twitter.com/GoosenWayne' }
]
---

<header
	id='site-header'
	class='fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-slate-950/95 backdrop-blur-xl border-b border-slate-800/50'
>
	<div class='container mx-auto px-6'>
		<div class='flex items-center justify-between h-20'>
			<!-- Logo -->
			<a
				href='/'
				class='text-2xl font-bold tracking-tighter text-white hover:text-orange-400 transition-colors'
			>
				Wayne Goosen
			</a>

			<!-- Desktop Navigation -->
			<div class='hidden md:flex items-center gap-6'>
				{
					navLinks.map((link) => (
						<a
							href={link.href}
							class='text-slate-400 hover:text-white transition-colors text-sm font-medium uppercase tracking-wider'
						>
							{link.label}
						</a>
					))
				}

				<a
					href='/#contact'
					class='px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white rounded-lg font-bold text-sm transition-all shadow-lg shadow-orange-600/20'
				>
					Let's Chat
				</a>
			</div>

			<!-- Mobile Menu Button -->
			<button
				id='mobile-menu-btn'
				class='w-10 h-10 flex items-center justify-center text-white md:hidden'
				aria-label='Toggle menu'
			>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					class='h-6 w-6'
					fill='none'
					viewBox='0 0 24 24'
					stroke='currentColor'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						stroke-width='2'
						d='M4 6h16M4 12h16M4 18h16'></path>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile Menu -->
	<div
		id='mobile-menu'
		class='hidden md:hidden bg-slate-950/95 backdrop-blur-xl border-t border-slate-800'
	>
		<div class='container mx-auto px-6 py-6 space-y-4'>
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class='block text-slate-400 hover:text-white transition-colors text-lg font-medium py-2'
					>
						{link.label}
					</a>
				))
			}

			<div class='pt-4 border-t border-slate-800'>
				<div class='flex gap-6 text-slate-400'>
					{
						socialLinks.map((link) => (
							<a
								href={link.url}
								target='_blank'
								rel='noopener noreferrer'
								class='hover:text-orange-400 transition-colors text-sm'
							>
								{link.name}
							</a>
						))
					}
				</div>
			</div>

			<a
				href='/#contact'
				class='block w-full px-6 py-3 bg-orange-600 hover:bg-orange-500 text-white rounded-lg font-bold text-center transition-all mt-4'
			>
				Let's Chat
			</a>
		</div>
	</div>
</header>

<!-- Spacer to account for fixed header -->
<div class='h-20'></div>

<script>
	let header: HTMLElement | null
	let mobileMenuBtn: HTMLElement | null
	let mobileMenu: HTMLElement | null

	function handleScroll() {
		if (header) {
			if (window.scrollY > 50) {
				header.classList.remove('bg-slate-950/95', 'border-slate-800/50')
				header.classList.add('bg-slate-950', 'border-slate-800')
			} else {
				header.classList.remove('bg-slate-950', 'border-slate-800')
				header.classList.add('bg-slate-950/95', 'border-slate-800/50')
			}
		}
	}

	function handleMobileMenuToggle() {
		mobileMenu?.classList.toggle('hidden')
	}

	function handleMobileLinkClick() {
		mobileMenu?.classList.add('hidden')
	}

	function initHeader() {
		header = document.getElementById('site-header')
		mobileMenuBtn = document.getElementById('mobile-menu-btn')
		mobileMenu = document.getElementById('mobile-menu')

		window.addEventListener('scroll', handleScroll)
		mobileMenuBtn?.addEventListener('click', handleMobileMenuToggle)
		mobileMenu?.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', handleMobileLinkClick)
		})
	}

	function cleanupHeader() {
		window.removeEventListener('scroll', handleScroll)
		mobileMenuBtn?.removeEventListener('click', handleMobileMenuToggle)
		mobileMenu?.querySelectorAll('a').forEach((link) => {
			link.removeEventListener('click', handleMobileLinkClick)
		})
	}

	// Initialize on page load (astro:page-load fires on initial load too)
	document.addEventListener('astro:page-load', initHeader)
	document.addEventListener('astro:before-swap', cleanupHeader)
</script>
