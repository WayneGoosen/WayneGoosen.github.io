---
export interface Props {
	tag: string
}
const { tag } = Astro.props
---

<a href={`/tags/${tag.toLowerCase()}`} aria-label={tag}>
	<span
		class='bg-orange-600/20 border border-orange-600/30 font-semibold text-orange-400 shadow text-sm w-fit px-2 py-1 md:px-5 md:py-2 rounded-full hover:bg-orange-600/30 transition-colors'
	>
		{tag ?? 'Blog Tag'}
	</span>
</a>
