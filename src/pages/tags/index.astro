---
import BaseLayout from '@/layouts/BaseLayout'
import TitlePage from '@/components/TitlePage'
import { getTags } from '@/utils'
const tags = await getTags()
---

<BaseLayout
	title='Tags'
	description='See all available tags on the blog and be able to filter posts by them.'
	isNoIndex={true}
>
	<TitlePage title='Tags' />
	<div class='flex justify-center flex-wrap gap-4'>
		{
			tags.map((tag) => (
				<a
					href={`/tags/${tag}`}
					class='inline-block bg-slate-800 border border-slate-700 rounded-full px-4 py-2 text-sm font-semibold text-slate-300 hover:border-orange-500/40 hover:text-orange-400 transition-colors mr-2 mb-2'
				>
					#{tag}
				</a>
			))
		}
	</div>
</BaseLayout>
